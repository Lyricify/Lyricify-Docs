<script is:inline>
	(() => {
		const storageKey = 'lyricify-docs-locale';
		const listenerKey = '__lyricifyDocsLanguagePreferenceBound';

		const getLocaleFromHref = (href) => {
			if (href.startsWith('/en/') || href === '/en/' || href === '/en') return 'en';
			if (href.startsWith('/zh-hant/') || href === '/zh-hant/' || href === '/zh-hant') return 'zh-Hant';
			return 'zh-CN';
		};

		const getPreferredLocale = () => {
			const saved = window.localStorage.getItem(storageKey);
			if (saved === 'en' || saved === 'zh-CN' || saved === 'zh-Hant') return saved;
			if (saved === 'zh-TW') return 'zh-Hant';

			const languages = navigator.languages && navigator.languages.length > 0
				? navigator.languages
				: [navigator.language];
			if (languages.some((lang) => ['zh-tw', 'zh-hk', 'zh-mo'].some((prefix) => lang.toLowerCase().startsWith(prefix)))) {
				return 'zh-Hant';
			}
			return languages.some((lang) => lang.toLowerCase().startsWith('zh')) ? 'zh-CN' : 'en';
		};

		const isRootPath = () => {
			const { pathname } = window.location;
			return pathname === '/' || pathname === '/index.html';
		};

		const preferredLocale = getPreferredLocale();
		if (isRootPath()) {
			if (preferredLocale === 'en') {
				window.location.replace('/en/');
				return;
			}
			if (preferredLocale === 'zh-Hant') {
				window.location.replace('/zh-hant/');
				return;
			}
		}

		if (!window[listenerKey]) {
			document.addEventListener('change', (event) => {
				const target = event.target;
				if (!(target instanceof HTMLSelectElement)) return;
				if (!target.closest('starlight-lang-select')) return;
				window.localStorage.setItem(storageKey, getLocaleFromHref(target.value));
			});
			window[listenerKey] = true;
		}
	})();
</script>
