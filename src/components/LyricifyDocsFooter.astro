---
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import { Icon } from '@astrojs/starlight/components';
import LanguagePreferenceScript from './LanguagePreferenceScript.astro';

const currentYear = new Date().getFullYear();
const locale = Astro.currentLocale ?? Astro.locals.starlightRoute?.lang ?? 'zh-CN';
const copyrightText = locale.toLowerCase().startsWith('en')
	? `Copyright © ${currentYear} WXRIW. All rights reserved.`
	: `版权所有 © ${currentYear} WXRIW，保留所有权利`;
const { editUrl, isFallback, entry } = Astro.locals.starlightRoute;
const isSplashPage = entry.data.template === 'splash';
const showCustomEditLink = Boolean(editUrl && !isFallback && !isSplashPage);
const editLinkText = locale.toLowerCase().startsWith('en')
	? 'Edit this page on GitHub'
	: '在 GitHub 上编辑此页';
---

<footer class="sl-flex">
	<div class="meta sl-flex">
		<LastUpdated />
	</div>

	{
		showCustomEditLink && (
			<div class="edit-link-wrap not-content">
				<a href={editUrl} class="edit-link-card">
					<Icon name="pencil" size="1rem" />
					<span>{editLinkText}</span>
				</a>
			</div>
		)
	}

	<Pagination />

	<div class="lyricify-footer not-content">
		<div class="brand">
			<img class="logo" src="/Lyricify-icon.png" alt="Lyricify Icon" />
			<div class="text">
				<p class="name">Lyricify</p>
				<p class="copyright">{copyrightText}</p>
			</div>
		</div>
	</div>

	<LanguagePreferenceScript />
	<script is:inline>
		(() => {
			const syncCurrentSidebarItemIntoView = () => {
				const mediaQuery = window.matchMedia('(min-width: 50rem)');
				if (!mediaQuery.matches) return;

				const sidebarScroller = document.getElementById('starlight__sidebar');
				const currentLink = sidebarScroller?.querySelector("a[aria-current='page']");
				if (!(sidebarScroller instanceof HTMLElement) || !(currentLink instanceof HTMLElement)) return;

				const scrollerRect = sidebarScroller.getBoundingClientRect();
				const linkRect = currentLink.getBoundingClientRect();
				const lineHeight = parseFloat(window.getComputedStyle(currentLink).lineHeight) || 24;
				const threshold = lineHeight * 2;
				const idealOffset = sidebarScroller.clientHeight * 0.25;
				const maxScrollTop = Math.max(0, sidebarScroller.scrollHeight - sidebarScroller.clientHeight);
				const spaceAbove = linkRect.top - scrollerRect.top;
				const spaceBelow = scrollerRect.bottom - linkRect.bottom;
				const isFullyAboveViewport = linkRect.bottom <= scrollerRect.top;
				const isFullyBelowViewport = linkRect.top >= scrollerRect.bottom;
				const isFullyOutOfView = isFullyAboveViewport || isFullyBelowViewport;

				let nextScrollTop = null;
				if (isFullyOutOfView) {
					const targetScrollTop =
						sidebarScroller.scrollTop + (linkRect.top - scrollerRect.top) - idealOffset;
					nextScrollTop = Math.min(Math.max(0, targetScrollTop), maxScrollTop);
				} else if (spaceAbove < threshold) {
					nextScrollTop = Math.max(0, sidebarScroller.scrollTop - (threshold - spaceAbove));
				} else if (spaceBelow < threshold) {
					nextScrollTop = Math.min(
						maxScrollTop,
						sidebarScroller.scrollTop + (threshold - spaceBelow)
					);
				}

				if (typeof nextScrollTop === 'number' && Math.abs(sidebarScroller.scrollTop - nextScrollTop) > 2) {
					sidebarScroller.scrollTo({
						top: nextScrollTop,
						behavior: 'smooth',
					});
				}
			};

			const run = () => window.requestAnimationFrame(syncCurrentSidebarItemIntoView);
			document.addEventListener('astro:page-load', run);
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', run, { once: true });
			} else {
				run();
			}
		})();
	</script>
</footer>

<style>
	@layer starlight.core {
		footer {
			flex-direction: column;
			gap: 1.5rem;
		}

		.meta {
			gap: 0.75rem 3rem;
			justify-content: space-between;
			flex-wrap: wrap;
			margin-top: 3rem;
			font-size: var(--sl-text-sm);
			color: var(--sl-color-gray-3);
		}

		.meta > :global(p:only-child) {
			margin-inline-start: auto;
		}
	}

	.lyricify-footer {
		margin-top: 1rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--sl-color-gray-6);
	}

	.edit-link-wrap {
		margin-top: 0.25rem;
	}

	.edit-link-card {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		color: var(--sl-color-gray-3);
		font-size: var(--sl-text-sm);
		font-weight: 400;
		line-height: 1.4;
		text-decoration: none;
	}

	.edit-link-card:hover {
		color: var(--sl-color-white);
		text-decoration: none;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.875rem;
	}

	.logo {
		width: 2.75rem;
		height: 2.75rem;
		flex: 0 0 auto;
	}

	.text {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.name,
	.copyright {
		margin: 0;
	}

	.name {
		font-size: var(--sl-text-base);
		font-weight: 700;
		color: var(--sl-color-white);
	}

	.copyright {
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
	}

	@media (max-width: 40rem) {
		.brand {
			align-items: flex-start;
		}
	}
</style>
